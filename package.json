{
  "name": "llm-interactive-share",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --config vite.config.ts",
    "build": "react-router build --config vite.config.ts",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "docs:lint": "node scripts/docs-lint.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "verify:iteration": "pnpm run docs:lint && pnpm run typecheck && pnpm run test:unit && pnpm run test:e2e"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14",
    "isbot": "^5"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^8.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
